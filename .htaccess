SetEnv PHP_VER 8_2

RewriteEngine On

# Redirection canonique : www.toutcuit.ch → toutcuit.ch
RewriteCond %{HTTP_HOST} ^www\.toutcuit\.ch$ [NC]
RewriteRule ^(.*)$ https://toutcuit.ch/$1 [R=301,L]

# Redirects: old routes → new routes
RewriteRule ^admin$ /expert [R=301,L]
RewriteRule ^superadmin$ /editor [R=301,L]

# Permet d'accéder aux fichiers HTML sans l'extension .html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !\.php$ [NC]
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# Protection anti-indexation
Header set X-Robots-Tag "noindex, nofollow, noarchive, nosnippet"